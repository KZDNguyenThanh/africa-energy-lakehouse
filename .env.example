# Copy this file to .env and fill in your credentials.
# cp .env.example .env

# MotherDuck (DuckDB cloud) access token — required for ingestion, dbt, ML, dashboard
MOTHERDUCK_TOKEN=

# Hugging Face access token — required to download the source dataset
HF_TOKEN=

# Groq API key — required for the GenBI assistant tab in the dashboard
GROQ_API_KEY=
